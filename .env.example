# ──────────────────────────────────────────────────────────────
# HALE — environment variables  (copy to .env.local, never commit secrets)
# EXPO_PUBLIC_* are bundled into the client. Server-only keys live in
# Convex env vars (set via `npx convex env set NAME value`), NOT here.
# ──────────────────────────────────────────────────────────────

# Convex (written by `npx convex dev`)
EXPO_PUBLIC_CONVEX_URL=
EXPO_PUBLIC_CONVEX_SITE_URL=

# PostHog (project "HALE" already exists) — public project key + host
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# RevenueCat — public SDK keys (per platform)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT=HALE+

# OneSignal — public App ID (REST key is server-side, in Convex env)
EXPO_PUBLIC_ONESIGNAL_APP_ID=

# Sentry — public DSN
EXPO_PUBLIC_SENTRY_DSN=

# ── Server-only (set in Convex env, listed here for reference) ──
# ANTHROPIC_API_KEY=          # Sage coach (Convex action — NEVER on device)
# ONESIGNAL_REST_API_KEY=     # behavior-triggered pushes from Convex
# RESEND_API_KEY=             # lifecycle email
# REVENUECAT_WEBHOOK_SECRET=  # verify RC webhook → set users.premium
