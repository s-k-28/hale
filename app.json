{
  "expo": {
    "name": "HALE",
    "slug": "hale",
    "version": "1.0.0",
    "description": "Quit nicotine for good. HALE gives you a personalized quit plan, a craving SOS toolkit, an AI coach in your corner, and a buddy to keep you honest — so you stay clean one day at a time.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hale",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0F0D",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.haleapp.hale",
      "icon": "./assets/images/icon.png",
      "supportsTablet": false,
      "associatedDomains": [
        "applinks:go.haleapp.com"
      ]
    },
    "android": {
      "package": "com.haleapp.hale",
      "adaptiveIcon": {
        "backgroundColor": "#0B0F0D",
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "go.haleapp.com",
              "pathPrefix": "/r/"
            },
            {
              "scheme": "https",
              "host": "go.haleapp.com",
              "pathPrefix": "/u/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0F0D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "dark": {
            "backgroundColor": "#0B0F0D",
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-sharing",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.haleapp.hale.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.haleapp.hale.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "5d7e5cd6-959a-42d3-9443-5cf70efa6971"
      },
      "router": {}
    },
    "owner": "s-k-28"
  }
}
