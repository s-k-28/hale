{
  "expo": {
    "name": "HALE",
    "slug": "hale",
    "version": "1.0.0",
    "description": "Quit nicotine for good. HALE gives you a personalized quit plan, a craving SOS toolkit, an AI coach in your corner, and a buddy to keep you honest — so you stay clean one day at a time.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hale",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0C0B",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.haleapp.hale",
      "icon": "./assets/images/icon.png",
      "supportsTablet": false
    },
    "android": {
      "package": "com.haleapp.hale",
      "adaptiveIcon": {
        "backgroundColor": "#0A0C0B",
        "foregroundImage": "./assets/images/adaptive-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "onesignal-expo-plugin",
        {
          "mode": "development"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0C0B",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "dark": {
            "backgroundColor": "#0A0C0B",
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 120
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      "expo-sharing",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
